# postgresql://{username}:{password}@{host}:{port}/{database_name}
DATABASE_URL=postgresql://postgres:1234@localhost:5432/mashup

# Option A) Use a single Redis URL (highest priority)
REDIS_URL=redis://:password@localhost:6379/0

# Option B) Use discrete connection fields (used when REDIS_URL is empty)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

# Cors Origins
CORS_ORIGINS=http://localhost:4200

# Naver OAuth
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Auth tokens
JWT_ACCESS_TOKEN_SECRET=
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=1209600
